# ─── apps/api (copy to apps/api/.env) ───────────────────────────────────────

# Database — default is a local SQLite file (zero setup).
# For Supabase: dashboard -> Connect -> Session pooler URI, then change the
# scheme from postgresql:// to postgresql+psycopg://
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=sqlite:///./shooting_star.db

# LLM — "ollama" (local or cloud) or "mock" (deterministic, offline)
LLM_PROVIDER=ollama

# Local Ollama (default): install from ollama.com, then `ollama pull qwen3:8b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_API_KEY=

# Ollama Cloud (free tier at ollama.com — sign up, create an API key):
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=<your key>
# OLLAMA_MODEL=gpt-oss:20b

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── apps/web (copy to apps/web/.env) ───────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
