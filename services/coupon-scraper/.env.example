# Copy to: services/coupon-scraper/.env
# Get the real DATABASE_URL from the team's shared secrets (ask Deshna) -
# NEVER put real credentials in this file, it's committed to git and meant
# as a template.

DATABASE_URL=postgresql+psycopg://username:password@host:5432/dbname
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Must match backend's JWT_SECRET exactly - a token issued by backend's
# login is verified here too. Same value as backend/.env's JWT_SECRET.
JWT_SECRET=dev-secret-change-me

# Where this service looks up a new user's starting KP balance the first
# time it sees them (see routes/transactions.py's _bootstrap_user docstring
# for why). Point this at wherever the main backend actually runs.
BACKEND_API_BASE_URL=http://localhost:8000

# Leave DATABASE_URL unset (or delete the line) to fall back to a local
# SQLite file for standalone testing without touching the shared DB.

# Run this service on a DIFFERENT port from backend (8000 is taken):
#   uvicorn main:app --reload --port 8001
