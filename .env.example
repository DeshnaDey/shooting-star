# ─── backend (copy to backend/.env) ─────────────────────────────────────────

# Database — default is a local SQLite file (zero setup, no network).
# For Supabase: dashboard -> Connect -> Transaction pooler URI (port 6543),
# change scheme to postgresql+psycopg://, URL-encode any @ in the password as
# %40, and append ?prepare_threshold=0. Requires a network that can reach
# pooler.supabase.com.
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?prepare_threshold=0
DATABASE_URL=sqlite:///./shooting_star.db

# LLM — "ollama" (local or cloud) or "mock" (deterministic, offline)
LLM_PROVIDER=ollama

# Local Ollama (default): install from ollama.com, then `ollama pull qwen3:8b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_API_KEY=

# Ollama Cloud (free tier at ollama.com — sign up, create an API key):
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=<your key>
# OLLAMA_MODEL=gpt-oss:20b

# Concept Visualiser — the narrated "Video Overview" (spoken walkthrough +
# animated flowcharts/mindmaps) runs entirely in the browser with ZERO config
# and no API keys or costs.

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── frontend (copy to frontend/.env) ───────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
